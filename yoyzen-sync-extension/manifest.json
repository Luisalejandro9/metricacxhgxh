{
  "manifest_version": 3,
  "name": "Yoyzen Data Sync",
  "version": "1.0",
  "description": "Sincroniza métricas de Yoyzen con tu tablero de gestión de forma automática.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.yoyzen.com/*",
        "https://human-agent-tecob2c.ysocial.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://human-agent-tecob2c.ysocial.net/*"
  ]
}
